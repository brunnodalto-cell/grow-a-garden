<audio id="musica" loop>
  <source src="musica.mp3" type="audio/mpeg">
</audio>

<button onclick="tocarMusica()" style="
position:fixed;
bottom:20px;
left:20px;
padding:10px;
border-radius:10px;
background:#22c55e;
color:white;
border:none;">
🎵 Música
</button>

<script>
function tocarMusica(){
  let audio = document.getElementById("musica");
  audio.play();
}
</script>